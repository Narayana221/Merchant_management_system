# Server Configuration
PORT=3000

# Database Configuration (PostgreSQL connection string)
# Format: postgresql://username:password@host:port/database
DB_URL=postgresql://your_db_user:your_db_password@localhost:5432/merchant_management_system_db

# JWT Configuration (use strong random strings in production)
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
